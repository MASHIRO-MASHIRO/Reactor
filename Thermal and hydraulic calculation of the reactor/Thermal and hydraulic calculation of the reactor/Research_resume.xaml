<Window x:Name="research_resume" x:Class="Thermal_and_hydraulic_calculation_of_the_reactor.Research_resume"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Thermal_and_hydraulic_calculation_of_the_reactor" xmlns:dvc="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
        mc:Ignorable="d"
        Title="Завершение исследования" Height="671" Width="1041" Icon="/atom_icon.png" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Closed="research_resume_Closed">
    <Window.Background>
        <RadialGradientBrush>
            <GradientStop Color="#FF282F37" Offset="1"/>
            <GradientStop Color="#FF646C74"/>
        </RadialGradientBrush>
    </Window.Background>
    <Canvas Margin="0,0,-23,-71">
        <Rectangle Stroke="Black" Height="145" Width="128" Canvas.Left="32" Canvas.Top="68">
            <Rectangle.Resources>
                <Style TargetType="{x:Type Rectangle}">
                    <Setter Property="RadiusX"  Value="10"/>
                    <Setter Property="RadiusY"  Value="10"/>
                </Style>
            </Rectangle.Resources>
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6C737A" Offset="0.013"/>
                    <GradientStop Color="#FF343737" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <TextBlock Canvas.Left="36" TextWrapping="Wrap" TextAlignment="Center" Text="Панель действий" Canvas.Top="75" Foreground="#FF4FD9FF" Height="32" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button x:Name="calculate" Content="Создать" Canvas.Left="51" FontFamily="Candara" FontSize="16" Height="30" Width="90" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Canvas.Top="118" HorizontalAlignment="Left" VerticalAlignment="Top" Click="calculate_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="exit" Content="Назад" Canvas.Left="51" FontFamily="Candara" FontSize="16" Height="30" Width="90" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Canvas.Top="163" Click="exit_Click" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <TextBox x:Name="title" TextWrapping="NoWrap" MaxLength="50" VerticalContentAlignment="Center" Background="#FF262C33" SelectionBrush="#FF2A3038" BorderBrush="#FF262C33" FontSize="18" Foreground="#FF4FD9FF" FontFamily="Candara" TextChanged="title_TextChanged" Height="34" Canvas.Left="213" Canvas.Top="123" Width="237" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock Canvas.Left="213" TextWrapping="Wrap" Canvas.Top="93" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Width="151" HorizontalAlignment="Left" VerticalAlignment="Top"><Run Language="ru-ru" Text="Название:"/></TextBlock>
        <Canvas Height="467" Width="755" Canvas.Left="224" Canvas.Top="106">
            <WindowsFormsHost Height="232" Width="392" Canvas.Left="364" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Top="-16">
                <dvc:Chart x:Name="chart1"/>
            </WindowsFormsHost>
            <WindowsFormsHost Height="232" Width="392" Canvas.Left="364" Canvas.Top="253" HorizontalAlignment="Center" VerticalAlignment="Top">
                <dvc:Chart x:Name="chart2"/>
            </WindowsFormsHost>
            <DataGrid x:Name="DataResearch" Height="332" Width="495" Canvas.Top="176" Canvas.Left="-189" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Candara" FontSize="16" CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserSortColumns="False" IsReadOnly="True" MinColumnWidth="300" HorizontalScrollBarVisibility="Disabled"/>
        </Canvas>
        <TextBlock Canvas.Left="561" TextWrapping="Wrap" Canvas.Top="38" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Width="225" HorizontalAlignment="Left" VerticalAlignment="Center"><Run Language="ru-ru" Text="Температурные г"/><Run Text="рафики:"/></TextBlock>
        <Rectangle Stroke="Black" Height="550" Width="449" Canvas.Left="561" Canvas.Top="65" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Rectangle.Resources>
                <Style TargetType="{x:Type Rectangle}">
                    <Setter Property="RadiusX"  Value="10"/>
                    <Setter Property="RadiusY"  Value="10"/>
                </Style>
            </Rectangle.Resources>
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6C737A" Offset="0.013"/>
                    <GradientStop Color="#FF343737" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <TextBlock Canvas.Left="36" TextWrapping="Wrap" Canvas.Top="252" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Width="277" HorizontalAlignment="Left" VerticalAlignment="Center"><Run Text="Теплогидравлические характе"/><Run Language="ru-ru" Text="р"/><Run Text="истики"/><Run Text=":"/></TextBlock>
        <TextBlock Canvas.Left="213" TextWrapping="Wrap" Canvas.Top="173" Foreground="#FFBABFC4" FontSize="16" FontFamily="Candara" Height="40" Width="151" HorizontalAlignment="Left" VerticalAlignment="Top"><Run Language="ru-ru" Text="Статус исследования:"/></TextBlock>
        <TextBlock x:Name="status" Canvas.Left="374" TextWrapping="Wrap" Canvas.Top="173" Foreground="ForestGreen" FontSize="16" FontFamily="Candara" Height="40" Width="151" HorizontalAlignment="Left" VerticalAlignment="Top"><Run Language="ru-ru" Text="Успешное"/></TextBlock>
    </Canvas>
</Window>
