        <TextBlock x:Name="date" Canvas.Left="340" TextWrapping="Wrap" Canvas.Top="206" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Width="214" HorizontalAlignment="Left" VerticalAlignment="Center"><Run Language="ru-ru" Text=""/></TextBlock>
        <TextBlock x:Name="mail_per" Canvas.Left="268" TextWrapping="Wrap" Canvas.Top="235" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Width="241" HorizontalAlignment="Left" VerticalAlignment="Center"><Run x:Name="mail" Language="ru-ru" Text=""/></TextBlock>

    </Canvas>
</Window>
