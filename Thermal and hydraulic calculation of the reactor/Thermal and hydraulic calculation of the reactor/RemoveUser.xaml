<Window x:Class="Thermal_and_hydraulic_calculation_of_the_reactor.RemoveUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Thermal_and_hydraulic_calculation_of_the_reactor"
        mc:Ignorable="d"
        Title="Удаление пользователя" Height="254" Width="494" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="/atom_icon.png">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF525961"/>
            <GradientStop Color="#FF0E1114" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Canvas Height="243" VerticalAlignment="Top">
        <Rectangle Stroke="Black" Height="145" Canvas.Left="25" Canvas.Top="35" Width="128" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Rectangle.Resources>
                <Style TargetType="{x:Type Rectangle}">
                    <Setter Property="RadiusX"  Value="10"/>
                    <Setter Property="RadiusY"  Value="10"/>
                </Style>
            </Rectangle.Resources>
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6C737A"/>
                    <GradientStop Color="#FF343737" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Text="Панель действий" Foreground="#FF4FD9FF" Height="32" Canvas.Left="29" Canvas.Top="44" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Button x:Name="remove_user" Content="Удалить" FontFamily="Candara" FontSize="16" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Height="30" Canvas.Left="43" Canvas.Top="87" Width="90" Click="remove_user_Click" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="exit" Content="Назад" FontFamily="Candara" FontSize="16" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Click="exit_Click" Height="30" Canvas.Left="43" Canvas.Top="132" Width="90" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <ComboBox x:Name="user_list" Width="165" Canvas.Left="245" Canvas.Top="102" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Top" Height="34" IsReadOnly="True"/>
        <TextBlock TextWrapping="Wrap" Background="#FF454F59" Height="34" Canvas.Left="212" Canvas.Top="102" Width="35" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Image Source="/user.png" Height="20" Canvas.Left="220" Canvas.Top="108" Width="22" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Image.OpacityMask>
                <ImageBrush ImageSource="/user.png"/>
            </Image.OpacityMask>
        </Image>
        <TextBlock TextWrapping="Wrap" Foreground="#FFBABFC4" FontSize="16" FontFamily="Candara" Height="40" Canvas.Left="212" Canvas.Top="68" Width="92" HorizontalAlignment="Center" VerticalAlignment="Top"><Run Text="Количество:"/><LineBreak/><Run/></TextBlock>
        <TextBlock x:Name="count_user" TextWrapping="Wrap" Foreground="#FF4FD9FF" FontSize="16" FontFamily="Candara" Height="40" Canvas.Left="304" Canvas.Top="68" Width="87" HorizontalAlignment="Center" VerticalAlignment="Top"/>
    </Canvas>
</Window>
