<Window x:Class="Thermal_and_hydraulic_calculation_of_the_reactor.ViewingResearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Thermal_and_hydraulic_calculation_of_the_reactor" xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        Title="Поиск исследований" Height="466" Width="944" WindowStartupLocation="CenterScreen" Closed="Window_Closed" Icon="/atom_icon.png">
    <Window.Resources>
        <Style TargetType="Button" x:Key="show">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <CollectionViewSource x:Key="control_values">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="title_research"/>
                <scm:SortDescription PropertyName="success_research"/>
                <scm:SortDescription PropertyName="Column2"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF151515"/>
            <GradientStop Color="#FF4E4E51" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Canvas Margin="0,0,45,0">
        <DataGrid x:Name="control_values" Height="297" Width="676" VirtualizingStackPanel.VirtualizationMode="Standard"  AutoGenerateColumns="True" ItemsSource="{Binding data}" Canvas.Left="212" Canvas.Top="68" HorizontalAlignment="Left" VerticalAlignment="Top" Loaded="DataGrid_Loaded" ClipToBounds="True" CanUserResizeColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserAddRows="False" CanUserResizeRows="False" SelectionMode="Single" IsReadOnly="True" FontSize="18" FontFamily="Candara" ColumnWidth="Auto" SelectionChanged="control_values_SelectionChanged" CanUserSortColumns="False">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding success_research}" Value="Провальное">
                            <Setter Property="Foreground" Value="IndianRed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding success_research}" Value="Успешное">
                            <Setter Property="Foreground" Value="ForestGreen"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
        <Rectangle Height="148" Canvas.Left="27" Stroke="Black" Canvas.Top="18" Width="127" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Rectangle.Resources>
                <Style TargetType="{x:Type Rectangle}">
                    <Setter Property="RadiusX"  Value="10"/>
                    <Setter Property="RadiusY"  Value="10"/>
                </Style>
            </Rectangle.Resources>
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6C737A"/>
                    <GradientStop Color="#FF343737" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <TextBlock Canvas.Left="30" TextWrapping="Wrap" TextAlignment="Center" Text="Панель действий" Canvas.Top="27" Foreground="#FF4FD9FF" Height="32" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button x:Name="show" Content="Просмотр" Canvas.Left="45" FontFamily="Candara" FontSize="16" Height="30" Width="90" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Canvas.Top="70" HorizontalAlignment="Left" VerticalAlignment="Top" Click="show_Click" IsEnabled="False">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="exit" Content="Назад" Canvas.Left="45" FontFamily="Candara" FontSize="16" Height="30" Width="90" Foreground="#FFEEF0F3" RenderTransformOrigin="0.5,0.5" Canvas.Top="113" Click="exit_Click" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF4FD9FF" Offset="1"/>
                    <GradientStop Color="#FF2A7886" Offset="0"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <TextBox x:Name="show_row" TextWrapping="NoWrap" VerticalContentAlignment="Center" Background="#FF262C33" SelectionBrush="#FF2A3038" BorderBrush="#FF262C33" FontSize="18" Foreground="#FF4FD9FF" FontFamily="Candara" Height="34" Canvas.Left="738" Canvas.Top="18" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center" TextChanged="show_row_TextChanged" GotFocus="show_row_GotFocus"/>
        <TextBlock Canvas.Left="645" TextWrapping="Wrap" TextAlignment="Center" Canvas.Top="28" Foreground="#FF4FD9FF" Height="32" Width="109" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" Text="Поиск:"/>
        <ComboBox x:Name="list" Canvas.Left="324" Canvas.Top="25" Width="126" IsEditable="False"  HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#FF262C33" SelectionChanged="list_SelectionChanged" BorderBrush="#FF262C33" FontSize="14" GotFocus="list_GotFocus">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FF262C33" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
        </ComboBox>
        <TextBox x:Name="filter" TextWrapping="NoWrap" VerticalContentAlignment="Center" Background="#FF262C33" SelectionBrush="#FF2A3038" BorderBrush="#FF262C33" FontSize="18" Foreground="#FF4FD9FF" FontFamily="Candara" Height="34" Canvas.Left="472" Canvas.Top="18" Width="150" HorizontalAlignment="Center" VerticalAlignment="Center" IsEnabled="False" TextChanged="filter_TextChanged" GotFocus="filter_GotFocus"/>
        <TextBlock Canvas.Left="212" TextWrapping="Wrap" TextAlignment="Center" Canvas.Top="28" Foreground="#FF4FD9FF" Height="32" Width="93" FontSize="16" Text="Фильтрация:" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <ComboBox x:Name="list_sort" Canvas.Left="324" Canvas.Top="384" Width="126" IsEditable="False" Foreground="#FF262C33" SelectionChanged="list_SelectionChanged" BorderBrush="#FF262C33" FontSize="14" GotFocus="list_GotFocus" HorizontalAlignment="Center" VerticalAlignment="Top">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FF262C33" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
        </ComboBox>
        <TextBlock Canvas.Left="212" TextWrapping="Wrap" TextAlignment="Center" Canvas.Top="387" Foreground="#FF4FD9FF" Height="32" Width="93" FontSize="16" Text="Сортировка:" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <ComboBox x:Name="sort_value" Canvas.Left="472" Canvas.Top="384" Width="126" IsEditable="False" Foreground="#FF262C33" SelectionChanged="sort_value_SelectionChanged" BorderBrush="#FF262C33" FontSize="14" GotFocus="list_GotFocus" HorizontalAlignment="Left" VerticalAlignment="Center">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FF262C33" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
        </ComboBox>
    </Canvas>
</Window>
